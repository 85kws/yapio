{
  "expo": {
    "name": "Yapio",
    "slug": "yapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "yapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B4BE7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yapp.builder",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMotionUsageDescription": "Adım sayar özelliği için hareket verisi kullanılır.",
        "NSCameraUsageDescription": "Üyelik/sadakat kartı QR kodunu okutmak için kamera kullanılır."
      }
    },
    "android": {
      "package": "com.yapp.builder",
      "adaptiveIcon": {
        "backgroundColor": "#5B4BE7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "yapp ile app'inize foto eklemek icin galeriye erisim ister."
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#5B4BE7"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Üyelik/sadakat kartı QR kodunu okutmak için kamera kullanılır."
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e78c3947-ad42-4b2a-8ef9-6df5663f7acc"
      }
    },
    "owner": "natehiggers"
  }
}
